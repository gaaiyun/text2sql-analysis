# ============================================================================
# Text2SQL 环境变量配置模板
# ============================================================================
# 
# 使用说明：
# 1. 复制此文件为 .env（开发环境）或 .env.local（本地测试）
# 2. 填入您的真实配置值
# 3. .env 和 .env.local 已在 .gitignore 中，不会被提交到 Git
#
# ⚠️ 重要：永远不要将包含真实密钥的文件提交到版本控制系统
# ============================================================================

# =============================================================================
# 火山方舟 Coding Plan（OpenAI-compatible）
# =============================================================================
# 获取地址：https://console.volcengine.com/ark
# 生产部署时在 Streamlit Cloud Advanced settings 中配置同名 secrets。
LLM_PROVIDER=volcengine_ark
VOLCENGINE_ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3
VOLCENGINE_ARK_API_KEY=your-volcengine-ark-api-key-here
VOLCENGINE_ARK_MODEL=glm-5.2
MODEL_TEMPERATURE=0.1

# 备用 Provider：DeepSeek（可选）
# 使用时设置 LLM_PROVIDER=deepseek，并配置以下三项。
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_MODEL=deepseek-v4-flash

# =============================================================================
# Streamlit 公网访问口令
# =============================================================================
APP_PASSWORD=change-me

# =============================================================================
# 阿里云百炼 API（旧入口可选）
# =============================================================================
DASHSCOPE_API_KEY=sk-your-dashscope-api-key-here
KIRO_API_KEY=kp-your-kiro-api-key-here
KIRO_BASE_URL=https://kiro.singforge.dpdns.org:11128/v1
KIRO_MODEL=claude-opus-4.6

# 旧脚本兼容变量（可选）
DB_HOST=your-db-host
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_NAME=znjz

# =============================================================================
# 数据库配置 - 场景 1-3（znjz 智能制造数据库）
# =============================================================================
# 用于：数据洞察、地区产业分析、行业分析
DB_HOST_SCENARIO_1_3=your-db-host
DB_PORT_SCENARIO_1_3=3306
DB_NAME_SCENARIO_1_3=znjz
DB_USER_SCENARIO_1_3=znjz
DB_PASSWORD_SCENARIO_1_3=your-db-password

# =============================================================================
# 数据库配置 - 场景 4-5（gaaiyun_2 数据库）
# =============================================================================
# 用于：招商清单、企业尽调
DB_HOST_SCENARIO_4_5=your-db-host
DB_PORT_SCENARIO_4_5=3306
DB_NAME_SCENARIO_4_5=gaaiyun_2
DB_USER_SCENARIO_4_5=your-db-user
DB_PASSWORD_SCENARIO_4_5=your-db-password

# =============================================================================
# Vanna AI（可选，用于 Text2SQL 兜底）
# =============================================================================
VANNA_API_KEY=your-vanna-api-key-here
VANNA_ORG=gaaiyun
VANNA_MODEL=chinook

# =============================================================================
# 可选配置
# =============================================================================
# 日志级别：DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# API 服务器端口
API_PORT=8000
VANNA_PORT=5000
